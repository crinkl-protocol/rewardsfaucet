{
  "cleanUrls": true,
  "headers": [
    { "source": "/index.html", "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }] },
    { "source": "/(.*)\\.(png|jpg|svg)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }] },
    { "source": "/(.*)\\.mp4", "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800" }] }
  ]
}
